# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
backend/.venv/
venv/

# --- Environment / secrets ---
.env
backend/.env

# --- ML outputs / artifacts ---
classification_output/
backend/classification_output/

# --- MLflow local tracking store (Phase A; opt-in mlflow logging) ---
# MLflow 3.x's local default is a sqlite backend (mlflow.db) + an ./mlruns artifact folder.
mlruns/
backend/mlruns/
mlflow.db
backend/mlflow.db

# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/node_modules/
*.local

# --- E2E (Playwright) test artifacts (Phase 10) ---
# (gitignore has no inline comments — keep patterns and notes on separate lines)
# throwaway OUTPUT_DIR the E2E backend writes to (outside Vite's watch):
backend/.e2e_output/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
# E2E uploads land in DATA_DIR/uploads — not real data:
backend/data/samples/uploads/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
