# ClassifyOS backend environment — copy to backend/.env and adjust paths.
# Never commit the real .env (see .gitignore).

# Input data root. The StorageAdapter resolves all reads under here.
# Convention: point this at a folder OUTSIDE the repo so datasets are never committed.
# Forward slashes are fine on Windows. Seed it from the committed backend/data/samples/.
DATA_DIR=C:/Projects/classifyos_data/input

# Output/artifact root. Models, plots, and JSON results are written under here.
# Also keep this outside the repo. The test suite ignores this and writes to a temp dir.
OUTPUT_DIR=C:/Projects/classifyos_data/output

# Comma-separated CORS allowlist for the API. Never use "*" outside local dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage backend (OPTIONAL) — Databricks Unity Catalog volumes (Phase B, §6.6 Step 1).
# Unset → LocalFolderStorage (DATA_DIR/OUTPUT_DIR above); a local run needs NONE of these.
# Set CLASSIFYOS_STORAGE_BACKEND=databricks (or just DBRICKS_INPUT_VOLUME) →
# DatabricksVolumeStorage, whose roots are the two /Volumes/... paths below. Unity Catalog
# volumes expose POSIX paths usable with plain open()/pandas, so the engine's file I/O is
# unchanged — this only re-points the storage roots. On the cluster these are set under
# Compute → Edit → Advanced → Environment Variables (locally, point them at any folders to test).
# CLASSIFYOS_STORAGE_BACKEND=databricks
# DBRICKS_INPUT_VOLUME=/Volumes/main/classifyos/data/input
# DBRICKS_OUTPUT_VOLUME=/Volumes/main/classifyos/data/output

# --- Databricks managed MLflow (OPTIONAL) — Phase B, §6.6 Step 3 (ZERO code).
# CLUSTER-SIDE ONLY: set these on the Databricks cluster (or in a notebook cell), NOT in a local
# backend/.env. mlflow_logging.py only READS MLFLOW_TRACKING_URI (it never sets a tracking URI),
# so setting it to "databricks" routes logging to the cluster's managed tracking server and
# "databricks-uc" routes the model registry to Unity Catalog — no engine change. Locally, leave
# these unset (MLflow uses its sqlite/./mlruns default) or point MLFLOW_TRACKING_URI at Postgres
# (Interim 2a above). A run must still opt in with mlflow.enabled=true to log anything.
# MLFLOW_TRACKING_URI=databricks
# MLFLOW_REGISTRY_URI=databricks-uc

# --- Databricks orchestration (OPTIONAL) — Phase B, §6.6 Step 6 (FastAPI → Databricks Jobs).
# Unset → CLASSIFYOS_EXECUTION_BACKEND defaults to "local": POST /api/v1/run runs the engine
# in-process and returns the full result envelope (today's behaviour; local dev + CI unchanged).
# Set CLASSIFYOS_EXECUTION_BACKEND=databricks on the Azure-hosted API to instead SUBMIT a
# Databricks Job and return {job_id, run_id}; the UI then polls GET /run/{job_id}/status and
# fetches GET /run/{job_id}/results (the same locked envelope, read from the UC output volume).
# The Jobs API calls use the SERVICE token (DATABRICKS_TOKEN); the user's PAT is passed per-request
# in the X-Databricks-Token header for Unity Catalog data access and is NEVER persisted.
# CLASSIFYOS_EXECUTION_BACKEND=databricks
# DATABRICKS_HOST=https://adb-XXXX.azuredatabricks.net
# DATABRICKS_TOKEN=dapiXXXXXXXX                 # SERVICE token — Jobs API only (never data access)
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXX # SQL warehouse path — the pre-run table-profile
#                                               # SAMPLE read (below) parses the <id> from this when
#                                               # DATABRICKS_SQL_WAREHOUSE_ID is unset.
# DATABRICKS_JOB_NOTEBOOK_PATH=/Repos/classifyos/notebooks/classifyos_job_runner  # the Job entrypoint
# DATABRICKS_JOB_CLUSTER_ID=0716-XXXXXX-abcd    # existing cluster the Job runs on
# DATABRICKS_JOB_WHEEL_PATH=/Volumes/main/classifyos/libs/classifyos-1.0.0-py3-none-any.whl
# DATABRICKS_JOB_TIMEOUT_SECONDS=3600           # Job wall-clock cap (cost guardrail; default 3600)
#
# Job state is STATELESS (§6.6 Step 6): the Databricks run_id returned by the submit IS the job_id
# the UI polls with, so GET /run/{job_id}/status and /results poll Databricks directly on every
# request. There is NO database for job state — Databricks is the only external dependency.
#
# Per-user Runs history (GET /api/v1/runs) in the databricks backend: the read-path AUTO-ROUTES to
# Databricks-managed MLflow (per-call tracking_uri="databricks"), so it does NOT depend on THIS
# process's MLFLOW_TRACKING_URI — DATABRICKS_HOST + DATABRICKS_TOKEN (service, above) are enough, and
# the service identity needs READ on the /Shared/classifyos experiment. The search is SCOPED to the
# ClassifyOS experiment (Databricks caps search_runs at 100 experiment_ids and a workspace holds many).
# Runs are filtered by the classifyos.user_email tag the Job logs, resolved on read from the caller's
# X-Databricks-Token PAT (SCIM). In the LOCAL backend the Runs view reads THIS process's store, lists all.
#
# CLASSIFYOS_MLFLOW_EXPERIMENT (OPTIONAL) — the experiment the databricks Runs read scopes to (default
# "classifyos"; matched by basename, so it resolves the Job's /Shared/classifyos). Set only if you log
# runs under a custom experiment name.
# CLASSIFYOS_MLFLOW_EXPERIMENT=classifyos

# --- Delta input source (OPTIONAL) — Phase B, §6.6 Step 4. NO env var needed here.
# A run sets input_source.type="delta" with a Unity Catalog catalog/schema/table (or a raw
# query); on a Databricks cluster the active SparkSession reads the Delta table → pandas → a
# Parquet snapshot under DBRICKS_INPUT_VOLUME, then the normal file pipeline runs on it. PySpark
# is cluster-provided; a local run with type="delta" raises a clear InputSourceError (use "file").

# --- Pre-run table profiling (OPTIONAL) — the databricks backend's Data-Profile / feature-picker.
# When a Unity Catalog table is picked, GET /api/v1/databricks/table-profile reads a BOUNDED SAMPLE
# of the table's real rows via the SQL Statement Execution API (POST /api/2.0/sql/statements, as the
# requesting user's PAT) and runs the SAME profiling a CSV upload does — so the Data Profile page and
# the Configuration feature picker populate (histograms, stats, correlation) just like a file/Postgres
# source. Display-only (reads only; the /run still reads the FULL table on the cluster). Needs a SQL
# warehouse: set DATABRICKS_SQL_WAREHOUSE_ID, or leave it unset to reuse the <id> from
# DATABRICKS_HTTP_PATH above. If neither is set (or the warehouse is unreachable) the picker degrades
# to the Unity Catalog schema alone — no rich stats, never blocked. The browsing user needs CAN USE
# on the warehouse + SELECT on the table. NOT used by the local backend.
# DATABRICKS_SQL_WAREHOUSE_ID=XXXXXXXXXXXX      # SQL warehouse for the profiling sample (else parsed
#                                               # from DATABRICKS_HTTP_PATH)
# CLASSIFYOS_DBRICKS_PROFILE_SAMPLE_ROWS=10000  # row cap for the profiling sample (default 10000)

# --- MLflow (OPTIONAL) — only used when a run enables MLflow logging (mlflow.enabled).
# Unset → MLflow uses its local default next to the process CWD: a sqlite `mlflow.db` backend
# store plus an `./mlruns` artifact folder (both gitignored). No server needed. Point
# MLFLOW_TRACKING_URI at a DB/managed server later without any code change (Interim 2a Postgres
# / Databricks managed tracking); the engine sets MLFLOW_ALLOW_FILE_STORE only for an explicit
# `file:` store (MLflow 3.x maintenance mode). Never commit real URIs.
# MLFLOW_TRACKING_URI=
#
# Interim 2a — MLflow backend store = a LOCAL Postgres, artifact store = a LOCAL folder.
# Uncomment BOTH to move run history/params/metrics into Postgres (SQL-queryable, survives a
# server restart) while keeping the PNGs/CSVs/run_profile.json/saved-model files as files.
# This is CONFIGURATION ONLY — no code change (the Phase-A logging code is store-agnostic).
#   * MLFLOW_TRACKING_URI: a `postgresql://user:pass@host:port/db` backend-store URI. MLflow's
#     SQLAlchemy backend uses the psycopg2 driver (requirements: psycopg2-binary). MLflow
#     auto-creates its tables on first use against an empty database.
#   * _MLFLOW_SERVER_ARTIFACT_ROOT: the artifact-root URI MLflow uses for NEW experiments when
#     the tracking store is a DB (read at experiment-creation time). Must be a `file://` URI on
#     Windows (a bare `C:/...` path is misparsed — the drive letter looks like a URI scheme).
#     Keep it OUTSIDE the repo, same convention as DATA_DIR/OUTPUT_DIR. Never commit real creds.
#     [MLflow-INTERNAL KNOB] The leading underscore is MLflow's own (semi-private) env var for the
#     default artifact root when a DB backend store is used client-side (with no `mlflow server`);
#     verified against mlflow 3.14.0. It works, but it is not a stable public API — RE-CHECK it on
#     any MLflow major/minor bump (the alternative is pre-creating the experiment with an explicit
#     artifact_location, which we avoided to keep this configuration-only).
# MLFLOW_TRACKING_URI=postgresql://classifyos:classifyos@localhost:5432/mlflow
# _MLFLOW_SERVER_ARTIFACT_ROOT=file:///C:/Projects/classifyos_data/mlflow-artifacts

# --- Postgres INPUT source (OPTIONAL) — Interim 2b (docs/databricks_integration.md §6.5).
# Only used when a run sets input_source.type = "postgres". The run's input_source.connection_env
# NAMES an env var (default below) that holds the SQLAlchemy DSN of the source database; the
# credential lives here (machine-local, gitignored), NEVER in the request/config. The configured
# table/query is run ONCE and materialized to input_file (a .parquet/.csv) under DATA_DIR, then
# the normal file pipeline runs on that snapshot (Option B — data_loader is unchanged). Driver:
# SQLAlchemy + psycopg2 (requirements: SQLAlchemy, psycopg2-binary). Never commit real creds.
# CLASSIFYOS_PG_DSN=postgresql://user:pass@localhost:5432/classifyos_data

# --- Azure OpenAI (OPTIONAL) — only needed for LLM reason-code narratives on the
# Explainability page (explainability.llm_narratives). Absent → per-row SHAP still works;
# the run just ships without narratives. Set these on the FASTAPI host (both backends read them
# here). Never commit real keys.
AZURE_OPEN_AI_ENDPOINT=
AZURE_OPEN_AI_API_KEY=
AZURE_OPEN_AI_API_VERSION=
AZURE_OPEN_AI_MODEL=
AZURE_OPEN_AI_DEPLOYMENT_NAME=
#
# LLM narratives on the DATABRICKS backend run OFF THE CLUSTER. The run executes on the cluster, which
# cannot reach the Azure OpenAI private endpoint (403 "Public access is disabled"). So the Job sets
# CLASSIFYOS_NARRATE_IN_ENGINE=false (below): the engine ships SHAP + an api/narration_context.json
# side artifact and SKIPS the Azure call, and FastAPI (which CAN reach the endpoint, using the
# AZURE_OPEN_AI_* above) generates the narratives via POST /api/v1/runs/{run_id}/narrate and
# re-persists the narrated run. Nothing Azure-related is pushed to the workspace (the earlier
# secret-scope handoff was removed). The LOCAL backend is unchanged: the engine narrates in-process.
#
# CLASSIFYOS_NARRATE_IN_ENGINE (OPTIONAL) — whether the ENGINE narrates in-process during a run.
# Default (unset) = true: local runs narrate as before. The Databricks Job sets it to "false" (in the
# notebook, not here) so the cluster skips the unreachable Azure call. You would only set it here to
# force a local engine NOT to narrate in-process (then narrate via POST /runs/{run_id}/narrate).
# CLASSIFYOS_NARRATE_IN_ENGINE=true
