# ClassifyOS backend environment — copy to backend/.env and adjust paths.
# Never commit the real .env (see .gitignore).

# Input data root. The StorageAdapter resolves all reads under here.
# Convention: point this at a folder OUTSIDE the repo so datasets are never committed.
# Forward slashes are fine on Windows. Seed it from the committed backend/data/samples/.
DATA_DIR=C:/Projects/classifyos_data/input

# Output/artifact root. Models, plots, and JSON results are written under here.
# Also keep this outside the repo. The test suite ignores this and writes to a temp dir.
OUTPUT_DIR=C:/Projects/classifyos_data/output

# Comma-separated CORS allowlist for the API. Never use "*" outside local dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- MLflow (OPTIONAL) — only used when a run enables MLflow logging (mlflow.enabled).
# Unset → MLflow uses its local default next to the process CWD: a sqlite `mlflow.db` backend
# store plus an `./mlruns` artifact folder (both gitignored). No server needed. Point
# MLFLOW_TRACKING_URI at a DB/managed server later without any code change (Interim 2a Postgres
# / Databricks managed tracking); the engine sets MLFLOW_ALLOW_FILE_STORE only for an explicit
# `file:` store (MLflow 3.x maintenance mode). Never commit real URIs.
# MLFLOW_TRACKING_URI=
#
# Interim 2a — MLflow backend store = a LOCAL Postgres, artifact store = a LOCAL folder.
# Uncomment BOTH to move run history/params/metrics into Postgres (SQL-queryable, survives a
# server restart) while keeping the PNGs/CSVs/run_profile.json/saved-model files as files.
# This is CONFIGURATION ONLY — no code change (the Phase-A logging code is store-agnostic).
#   * MLFLOW_TRACKING_URI: a `postgresql://user:pass@host:port/db` backend-store URI. MLflow's
#     SQLAlchemy backend uses the psycopg2 driver (requirements: psycopg2-binary). MLflow
#     auto-creates its tables on first use against an empty database.
#   * _MLFLOW_SERVER_ARTIFACT_ROOT: the artifact-root URI MLflow uses for NEW experiments when
#     the tracking store is a DB (read at experiment-creation time). Must be a `file://` URI on
#     Windows (a bare `C:/...` path is misparsed — the drive letter looks like a URI scheme).
#     Keep it OUTSIDE the repo, same convention as DATA_DIR/OUTPUT_DIR. Never commit real creds.
#     [MLflow-INTERNAL KNOB] The leading underscore is MLflow's own (semi-private) env var for the
#     default artifact root when a DB backend store is used client-side (with no `mlflow server`);
#     verified against mlflow 3.14.0. It works, but it is not a stable public API — RE-CHECK it on
#     any MLflow major/minor bump (the alternative is pre-creating the experiment with an explicit
#     artifact_location, which we avoided to keep this configuration-only).
# MLFLOW_TRACKING_URI=postgresql://classifyos:classifyos@localhost:5432/mlflow
# _MLFLOW_SERVER_ARTIFACT_ROOT=file:///C:/Projects/classifyos_data/mlflow-artifacts

# --- Postgres INPUT source (OPTIONAL) — Interim 2b (docs/databricks_integration.md §6.5).
# Only used when a run sets input_source.type = "postgres". The run's input_source.connection_env
# NAMES an env var (default below) that holds the SQLAlchemy DSN of the source database; the
# credential lives here (machine-local, gitignored), NEVER in the request/config. The configured
# table/query is run ONCE and materialized to input_file (a .parquet/.csv) under DATA_DIR, then
# the normal file pipeline runs on that snapshot (Option B — data_loader is unchanged). Driver:
# SQLAlchemy + psycopg2 (requirements: SQLAlchemy, psycopg2-binary). Never commit real creds.
# CLASSIFYOS_PG_DSN=postgresql://user:pass@localhost:5432/classifyos_data

# --- Azure OpenAI (OPTIONAL) — only needed for LLM reason-code narratives on the
# Explainability page (explainability.llm_narratives). Absent → per-row SHAP still works;
# the run just ships without narratives. Never commit real keys.
AZURE_OPEN_AI_ENDPOINT=
AZURE_OPEN_AI_API_KEY=
AZURE_OPEN_AI_API_VERSION=
AZURE_OPEN_AI_MODEL=
AZURE_OPEN_AI_DEPLOYMENT_NAME=
